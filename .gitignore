# Dependencies (created by npm i, yarn, or pnpm)
node_modules/
jspm_packages/
bower_components/

# Package manager lock files (often excluded in libraries, but keep for apps)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
out/
build/
release/

# Electron
electron-builder-output/
release-builds/

# VS Code
.vscode/
*.code-workspace
.history/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Custom: Ignore all static and image folders anywhere in the project
**/static/**
**/image/**